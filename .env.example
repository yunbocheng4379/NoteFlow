# NoteFlow production example.
# Copy this file to .env on the server, then change passwords/secrets before starting Docker.

# Public web port: http://SERVER_IP:APP_PORT
APP_PORT=3015

# Docker image registry prefix for builds. Use this when Docker Hub is slow in China.
BASE_REGISTRY=docker.m.daocloud.io

# Backend listens inside Docker. Keep 8483 unless you also update nginx/default.conf.
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8483

# Frontend build should normally call the same-origin nginx proxy.
VITE_API_BASE_URL=/api
VITE_SCREENSHOT_BASE_URL=/static/screenshots
VITE_FRONTEND_PORT=3015

ENV=production
STATIC=/static
OUT_DIR=./static/screenshots
NOTE_OUTPUT_DIR=note_results
IMAGE_BASE_URL=/static/screenshots
DATA_DIR=data
FFMPEG_BIN_PATH=

# Transcriber. tiny starts fastest; switch in UI later if you need better accuracy.
TRANSCRIBER_TYPE=fast-whisper
HF_ENDPOINT=https://huggingface.co
WHISPER_MODEL_SIZE=tiny
GROQ_TRANSCRIBER_MODEL=whisper-large-v3-turbo

# MySQL container credentials. Change all passwords.
MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=noteflow
MYSQL_USER=noteflow
MYSQL_PASSWORD=change-this-app-password

# docker-compose overrides backend DATABASE_URL to the internal mysql service.
# Keep this for non-Docker/local runs only.
DATABASE_URL=mysql+pymysql://noteflow:change-this-app-password@127.0.0.1:3306/noteflow

# Security. Generate fresh values for production.
JWT_SECRET_KEY=change-this-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
# Generate with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
COOKIE_ENCRYPT_KEY=mTdchlGJcCP3KgU4M3AxeRgZYkTEhcXZZ0n27SDh6FA=

# Optional SMTP notification. Leave empty to disable email sending.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
FRONTEND_URL=http://YOUR_SERVER_IP:3015
